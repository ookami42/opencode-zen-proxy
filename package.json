{
  "name": "opencode-zen-proxy",
  "version": "1.0.0",
  "description": "OpenAI-compatible proxy for OpenCode Zen API - access free models like DeepSeek V4 Flash",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/"
  },
  "keywords": ["opencode", "zen", "proxy", "openai-compatible", "ai", "deepseek"],
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js", "**/?(*.)+(spec|test).js"],
    "testPathIgnorePatterns": ["/node_modules/"]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
