# OpenCode Zen Proxy (keyless, direct-to-Zen mode)

PORT=3000
HOST=0.0.0.0

# Zen API base URL.
ZEN_API_BASE_URL=https://opencode.ai/zen/v1

# Bearer token sent to Zen. "public" (the default) unlocks the free-tier
# models without any login or local binary. Set a real Zen API key here to
# also access paid models.
ZEN_API_KEY=public

# --- Optional: gate client access to the proxy ---
# If set, clients must send this key in their Authorization header.
# When unset (default), the proxy is open for local use.
# CLIENT_API_KEY=

# Default reasoning effort for reasoning-capable models (deepseek-v4-flash-free, ...).
# Accepted values: low | medium | high | max | xhigh
# "xhigh" maximizes chain-of-thought length. Clients can override per-request
# via the "reasoning_effort" field.
DEFAULT_REASONING_EFFORT=xhigh

# Log level: debug, info, warn, error
LOG_LEVEL=info
